{
  "name": "magical-mixing-console",
  "productName": "Magical Mixing Console",
  "version": "2.2.0",
  "description": "An app for controlling X Air and M Air digital mixers, with the hope of supporting other mixers in the future.",
  "main": ".webpack/main",
  "workspaces": [
    "src/*"
  ],
  "scripts": {
    "electron-dev": "electron-forge start",
    "electron-make-arm64": "npx license-checker --production --out out/LICENSES.txt && cross-env NODE_ENV=production electron-forge make --arch=arm64",
    "electron-make-x64": "npx license-checker --production --out out/LICENSES.txt && cross-env NODE_ENV=production electron-forge make --arch=x64",
    "cap-android": "npx cap open android",
    "cap-ios": "npx cap open ios",
    "cap-dev": "cross-env NODE_ENV=development webpack --config webpack/capacitor.config.js --progress --mode production && npx cap sync",
    "cap-make": "cross-env NODE_ENV=production webpack --config webpack/capacitor.config.js --progress --mode production && npx cap sync",
    "cap-assets": "npx @capacitor/assets generate --android --iconBackgroundColor \"#ffffff\" --iconBackgroundColorDark \"#000000\" --splashBackgroundColor \"#ffffff\" --splashBackgroundColorDark \"#000000\" --logoSplashScale 0.5",
    "lint": "eslint ./src ./tests",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.mjs",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "digital",
    "mixer",
    "mixing",
    "console",
    "xair",
    "mair",
    "electron",
    "react",
    "capacitor"
  ],
  "author": {
    "name": "Matías Barrios",
    "email": "matias@magicalmixingconsole.com"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "@capacitor/cli": "^8.3.4",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-webpack": "^7.11.2",
    "@electron/fuses": "^2.1.1",
    "@electron/notarize": "^3.0.1",
    "@electron/osx-sign": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-loader": "^10.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "cssnano": "^8.0.1",
    "electron": "^42.0.0",
    "eslint": "^10.4.0",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "file-loader": "^6.2.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.10.1",
    "html-webpack-plugin": "^5.6.0",
    "node-loader": "^2.0.0",
    "postcss": "^8.4.33",
    "postcss-advanced-variables": "^5.0.0",
    "postcss-import": "^16.0.0",
    "postcss-loader": "^8.1.0",
    "raw-loader": "^4.0.2",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "url-loader": "^4.1.1",
    "vitest": "^4.1.8",
    "webpack": "^5.90.1",
    "webpack-bundle-analyzer": "^5.3.0",
