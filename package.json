    "@radix-ui/themes": "^3.2.1",
    "@use-gesture/react": "^10.3.1",
    "@webnativellc/capacitor-navigation-bar": "file:plugins/capacitor-navigation-bar",
    "autoprefixer": "^10.4.21",
    "buffer": "^6.0.3",
    "capacitor-udp-socket": "file:plugins/capacitor-udp-socket",
    "d3": "^7.8.5",
    "electron-squirrel-startup": "^1.0.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.6.2",
    "netmask": "^2.0.2",
    "os-locale": "^8.0.0",
    "process": "^0.11.10",
    "radix-ui": "^1.2.0",
    "react": "^19.1.0",
    "react-currency-input-field": "^4.0.5",
    "react-dom": "^19.1.0",
    "react-router": "^7.4.0",
    "react-swipeable": "^7.0.2",
    "stream-browserify": "^3.0.0"
  },
  "overrides": {
    "tar": "^7.5.15",
    "eslint": "$eslint",
    "@eslint/js": "$@eslint/js",
    "@electron/fuses": "$@electron/fuses",
    "@electron/asar": "^4.2.0"
  }
}
